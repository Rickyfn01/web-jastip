// Prisma schema for Neon PostgreSQL
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id              String   @id @default(uuid())
  customerName    String
  whatsappNumber  String
  productImage    String
  brand           String
  size            String?
  status          Status   @default(PENDING)
  storePrice      Float?
  finalPrice      Float?
  dpPercentage    Int
  dpAmount        Float?
  receiptImage    String?
  createdAt       DateTime @default(now())
}

enum Status {
  PENDING
  CHECKING
  READY_TO_PAY
  PAID_DP
  PURCHASED
  SHIPPED
  COMPLETED
}
